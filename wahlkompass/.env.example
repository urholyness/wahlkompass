# Copy to .env (which is gitignored) and fill in. Never commit real values.

# DIP API key — dip.bundestag.de (Authorization: ApiKey <key>).
# If it 401s, register a fresh free key (public demo key expired 05/2026).
DIP_API_KEY=

# Release signing (production): path to the held Ed25519/minisign private key.
# The demo builder generates an ephemeral key; replace with a held key for real releases.
RELEASE_SIGNING_KEY=

# Cloudflare (for wrangler deploy, set as CI secrets in production)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
